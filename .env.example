# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx
SUPABASE_MEDIA_BUCKET=songs

# AI provider
AI_PROVIDER=github

# GitHub Models
GITHUB_MODELS_API_KEY=xxx
GITHUB_MODELS_API_URL=https://models.inference.ai.azure.com/chat/completions
GITHUB_MODELS_MODEL=gpt-4.1
GITHUB_MODELS_FALLBACK_MODELS=

# Claude (optional)
ANTHROPIC_API_KEY=xxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# kie.ai Suno
KIE_API_KEY=xxx
KIE_API_BASE_URL=https://api.kie.ai
KIE_MODEL=suno-v4.5

# Creem.io
CREEM_TEST_MODE=true
CREEM_WEBHOOK_SECRET=xxx
CREEM_API_KEY=creem_test_xxx
CREEM_API_URL=https://test-api.creem.io/v1

# Site URLs
BASE_URL=http://localhost:3000
CREEM_SUCCESS_URL=http://localhost:3000/dashboard

# Creem Product IDs
CREEM_MINI_PRODUCT_ID=prod_xxx
CREEM_STANDARD_PRODUCT_ID=prod_xxx
CREEM_PRO_PACK_PRODUCT_ID=prod_xxx
CREEM_BASIC_MONTHLY_PRODUCT_ID=prod_xxx
CREEM_PRO_MONTHLY_PRODUCT_ID=prod_xxx
CREEM_BASIC_YEARLY_PRODUCT_ID=prod_xxx
CREEM_PRO_YEARLY_PRODUCT_ID=prod_xxx

# Email
RESEND_API_KEY=xxx
RESEND_FROM_EMAIL=Hit-Song <noreply@yourdomain.com>

# Cron
CRON_SECRET=xxx

# Dev/preview only
SKIP_CREDIT_CHECK=true
